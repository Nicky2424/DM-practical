// Practical 3
// Aim: To generate all permutations of a given set of digits.
//
// Problem Statement:
// Write a program that generates all the permutations of a given set of digits,
// with or without repetition.

#include <iostream>
using namespace std;

// Function for permutations without repetition
void permuteWithoutRep(string s, int l, int r) {
    if(l == r)
        cout << s << endl;
    else {
        for(int i = l; i <= r; i++) {
            swap(s[l], s[i]);
            permuteWithoutRep(s, l + 1, r);
            swap(s[l], s[i]); // backtrack
        }
    }
}

// Function for permutations with repetition
void permuteWithRep(string s, int n, string result, int index) {
    if(index == n) {
        cout << result << endl;
        return;
    }

    for(int i = 0; i < n; i++) {
        result[index] = s[i];
        permuteWithRep(s, n, result, index + 1);
    }
}

int main() {
    string s;
    int choice;

    cout << "Enter digits (as string): ";
    cin >> s;

    cout << "\n1. Without Repetition\n2. With Repetition\nEnter choice: ";
    cin >> choice;

    if(choice == 1) {
        permuteWithoutRep(s, 0, s.size() - 1);
    }
    else if(choice == 2) {
        string result = s;
        permuteWithRep(s, s.size(), result, 0);
    }
    else {
        cout << "Invalid choice";
    }

    return 0;
}
