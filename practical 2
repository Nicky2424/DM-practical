// Practical 2
// Aim: To implement a class RELATION using matrix representation
// and check its properties.
//
// Problem Statement:
// Create a class RELATION, use Matrix notation to represent a relation.
// Include member functions to check if the relation is:
// Reflexive, Symmetric, Anti-symmetric, Transitive.
// Using these functions, determine whether the given relation is:
// Equivalence Relation, Partial Order Relation, or None.

#include <iostream>
using namespace std;

class RELATION {
    int n;
    int a[10][10];

public:
    void input() {
        cout << "Enter number of elements: ";
        cin >> n;

        cout << "Enter adjacency matrix:\n";
        for(int i=0;i<n;i++)
            for(int j=0;j<n;j++)
                cin >> a[i][j];
    }

    bool isReflexive() {
        for(int i=0;i<n;i++)
            if(a[i][i] != 1)
                return false;
        return true;
    }

    bool isSymmetric() {
        for(int i=0;i<n;i++)
            for(int j=0;j<n;j++)
                if(a[i][j] != a[j][i])
                    return false;
        return true;
    }

    bool isAntisymmetric() {
        for(int i=0;i<n;i++)
            for(int j=0;j<n;j++)
                if(i != j && a[i][j] == 1 && a[j][i] == 1)
                    return false;
        return true;
    }

    bool isTransitive() {
        for(int i=0;i<n;i++)
            for(int j=0;j<n;j++)
                for(int k=0;k<n;k++)
                    if(a[i][j] && a[j][k] && !a[i][k])
                        return false;
        return true;
    }

    void checkRelation() {
        bool ref = isReflexive();
        bool sym = isSymmetric();
        bool anti = isAntisymmetric();
        bool trans = isTransitive();

        cout << "\nProperties:\n";
        cout << "Reflexive: " << (ref ? "Yes" : "No") << endl;
        cout << "Symmetric: " << (sym ? "Yes" : "No") << endl;
        cout << "Anti-symmetric: " << (anti ? "Yes" : "No") << endl;
        cout << "Transitive: " << (trans ? "Yes" : "No") << endl;

        cout << "\nResult: ";
        if(ref && sym && trans)
            cout << "Equivalence Relation";
        else if(ref && anti && trans)
            cout << "Partial Order Relation";
        else
            cout << "None";
    }
};

int main() {
    RELATION r;
    r.input();
    r.checkRelation();
}
